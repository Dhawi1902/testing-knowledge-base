                      <stringProp name="script">def counter = vars.get(&quot;BAR_COUNTER_1&quot;).toInteger()

// Increment counter for next poll
vars.put(&quot;BAR_COUNTER_1&quot;, String.valueOf(counter + 1))

// Safety check - max 100 polls to prevent infinite loop
if (counter &gt;= 800) {
   vars.put(&quot;CALC_COMPLETE_1&quot;, &quot;true&quot;)
   log.warn(&quot;Calculation cycle 1 timed out after 100 polls&quot;)
}</stringProp>
