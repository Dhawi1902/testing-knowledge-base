        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.jsoup.Jsoup

// Step 1: Clear all old SITS:Vision fields BEFORE extraction
def fieldsToRemove = []
vars.entrySet().each { entry -&gt;
    def name = entry.getKey()
    
    // Find all SITS:Vision fields
    if (name.contains(&apos;.MENSYS.&apos;) || 
        name.contains(&apos;.CAMS.&apos;) ||
        name.contains(&apos;.SMS.&apos;) ||
        name.contains(&apos;.SPR.&apos;) ||
        name.contains(&apos;.TTQ.&apos;) ||
        name.contains(&apos;.TTE.&apos;) ||
        name.contains(&apos;DUMMY&apos;) ||
        name.startsWith(&apos;FORM_&apos;) ||
        name.startsWith(&apos;R28_&apos;) ||
        name.startsWith(&apos;%&apos;) ||
        name.startsWith(&apos;#&apos;)) {
        fieldsToRemove.add(name)
    }
}

// Clear old fields
fieldsToRemove.each { fieldName -&gt;
    vars.remove(fieldName)
}

//if (fieldsToRemove.size() &gt; 0) {
//    log.info(&quot;Cleared ${fieldsToRemove.size()} old fields before extraction&quot;)
//}

// Step 2: Extract NEW fields from current response
def html = prev.getResponseDataAsString()
def doc = Jsoup.parse(html)
def count = 0

doc.select(&quot;input[type=hidden]&quot;).each { input -&gt;
    def name = input.attr(&quot;name&quot;)
    def value = input.attr(&quot;value&quot;)
    if (name &amp;&amp; value) {
        vars.put(name, value)
        count++
    }
}

//if (count &gt; 0) {
//    log.info(&quot;Extracted ${count} new hidden fields from ${prev.getSampleLabel()}&quot;)
//}
</stringProp>
        </JSR223PostProcessor>
        <hashTree/>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import org.apache.jmeter.protocol.http.util.HTTPArgument

// Get current sampler
def sampler = ctx.getCurrentSampler()

// Only inject if this is a POST request
if (sampler.getMethod() == &quot;POST&quot;) {
    def arguments = sampler.getArguments()
    
    // Get list of existing argument names
    def existingArgs = []
    arguments.getArguments().each { arg -&gt;
        existingArgs.add(arg.getName())
    }
    
    def injectedCount = 0
    
    // Find all extracted hidden fields and inject them
    vars.entrySet().each { entry -&gt;
        def name = entry.getKey()
        def value = entry.getValue()
        
        // Match SITS:Vision patterns
        if (name.contains(&apos;.MENSYS.&apos;) || 
            name.contains(&apos;.CAMS.&apos;) ||
            name.contains(&apos;.SMS.&apos;) ||
            name.contains(&apos;.TTQ.&apos;) ||
            name.contains(&apos;DUMMY&apos;) ||
            name.startsWith(&apos;FORM_&apos;) ||
            name.startsWith(&apos;R28_&apos;) ||
            name.startsWith(&apos;%&apos;) ||
            name.startsWith(&apos;#&apos;)) {
            
            // Only add if not already in sampler
            if (!existingArgs.contains(name)) {
                // Create proper HTTPArgument with encoding
                def arg = new HTTPArgument()
                arg.setName(name)
                arg.setValue(value)
                arg.setAlwaysEncoded(true)
                arg.setUseEquals(true)
                
                arguments.addArgument(arg)
                injectedCount++
            }
        }
    }
    
//    if (injectedCount &gt; 0) {
//        log.info(&quot;Injected ${injectedCount} fields into POST: ${sampler.getName()}&quot;)
//    }
}
</stringProp>
        </JSR223PreProcessor>
