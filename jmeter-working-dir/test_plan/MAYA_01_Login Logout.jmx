            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Detect Login Response" enabled="false">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// Check login response type: success, password_reset, or login_failed
def response = prev.getResponseDataAsString()

// Initialize flags
vars.put(&quot;NEEDS_PASSWORD_RESET&quot;, &quot;false&quot;)
vars.put(&quot;LOGIN_FAILED&quot;, &quot;false&quot;)

if (response.contains(&quot;successfully logged in&quot;)) {
    log.info(&quot;Login successful with current password&quot;)

} else if (response.contains(&quot;Password Maintenance&quot;) || response.contains(&quot;Password Change&quot;) || response.contains(&apos;action=&quot;SIW_PQS&quot;&apos;)) {
    log.info(&quot;Password reset required - extracting tokens&quot;)
    vars.put(&quot;NEEDS_PASSWORD_RESET&quot;, &quot;true&quot;)

    // Extract SCREEN_MODE token
    def screenModeMatch = response =~ /name=&quot;SCREEN_MODE\.DUMMY_BUTT\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (screenModeMatch.find()) {
        vars.put(&quot;PWD_SCREEN_MODE&quot;, screenModeMatch.group(1))
        log.info(&quot;Extracted SCREEN_MODE: &quot; + screenModeMatch.group(1))
    }

    // Extract DUMMY_BUTT token
    def dummyButtMatch = response =~ /name=&quot;%\.DUMMY_BUTT\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (dummyButtMatch.find()) {
        vars.put(&quot;PWD_DUMMY_BUTT&quot;, dummyButtMatch.group(1))
        log.info(&quot;Extracted DUMMY_BUTT: &quot; + dummyButtMatch.group(1))
    }

    // Extract DUMMY token (may be updated)
    def dummyMatch = response =~ /name=&quot;%\.DUMMY\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (dummyMatch.find()) {
        vars.put(&quot;PWD_DUMMY&quot;, dummyMatch.group(1))
        log.info(&quot;Extracted PWD_DUMMY: &quot; + dummyMatch.group(1))
    }

} else if (response.contains(&quot;Login Error&quot;) || response.contains(&quot;Invalid&quot;) || response.contains(&quot;incorrect&quot;) || response.contains(&quot;Log in&quot;)) {
    // Login failed - need to retry with NEW_PASSWORD
    log.info(&quot;Login failed with current password - will retry with NEW_PASSWORD&quot;)
    vars.put(&quot;LOGIN_FAILED&quot;, &quot;true&quot;)

    // Re-extract tokens for retry (they may have changed)
    def dummyMatch = response =~ /name=&quot;%\.DUMMY\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (dummyMatch.find()) {
        vars.put(&quot;DUMMY_TOKEN&quot;, dummyMatch.group(1))
    }
    def formTokenMatch = response =~ /name=&quot;FORM_VERIFICATION_TOKEN\.DUMMY\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (formTokenMatch.find()) {
        vars.put(&quot;FORM_VERIFICATION_TOKEN&quot;, formTokenMatch.group(1))
    }
    def webHeadMatch = response =~ /name=&quot;%\.WEB_HEAD\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (webHeadMatch.find()) {
        vars.put(&quot;WEB_HEAD_TOKEN&quot;, webHeadMatch.group(1))
    }
    def dummyBMatch = response =~ /name=&quot;%\.DUMMY_B\.MENSYS&quot; value=&quot;([^&quot;]+)&quot;/
    if (dummyBMatch.find()) {
        vars.put(&quot;DUMMY_B_TOKEN&quot;, dummyBMatch.group(1))
    }
} else {
    log.warn(&quot;Unexpected login response - check response data&quot;)
}
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
