              <hashTree/>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Detect Retry Login Response" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">// Check retry login response - update flags
def response = prev.getResponseDataAsString()

// Reset flags
vars.put(&quot;LOGIN_FAILED&quot;, &quot;false&quot;)

if (response.contains(&quot;successfully logged in&quot;)) {
    log.info(&quot;Retry login successful with NEW_PASSWORD&quot;)
    vars.put(&quot;NEEDS_PASSWORD_RESET&quot;, &quot;false&quot;)

    // Extract PORTAL_URL
    def portalMatch = response =~ /name=&quot;HREF\.DUMMY\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (portalMatch.find()) {
        vars.put(&quot;PORTAL_URL&quot;, portalMatch.group(1))
        log.info(&quot;Extracted PORTAL_URL: &quot; + portalMatch.group(1))
    }

    // Update PASSWORD to NEW_PASSWORD for consistency
    vars.put(&quot;PASSWORD&quot;, vars.get(&quot;NEW_PASSWORD&quot;))

} else if (response.contains(&quot;Password Maintenance&quot;) || response.contains(&quot;Password Change&quot;) || response.contains(&apos;action=&quot;SIW_PQS&quot;&apos;)) {
    log.info(&quot;Retry login requires password reset - extracting tokens&quot;)
    vars.put(&quot;NEEDS_PASSWORD_RESET&quot;, &quot;true&quot;)

    // Extract SCREEN_MODE token
    def screenModeMatch = response =~ /name=&quot;SCREEN_MODE\.DUMMY_BUTT\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (screenModeMatch.find()) {
        vars.put(&quot;PWD_SCREEN_MODE&quot;, screenModeMatch.group(1))
    }

    // Extract DUMMY_BUTT token
    def dummyButtMatch = response =~ /name=&quot;%\.DUMMY_BUTT\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (dummyButtMatch.find()) {
        vars.put(&quot;PWD_DUMMY_BUTT&quot;, dummyButtMatch.group(1))
    }

    // Extract DUMMY token
    def dummyMatch = response =~ /name=&quot;%\.DUMMY\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (dummyMatch.find()) {
        vars.put(&quot;PWD_DUMMY&quot;, dummyMatch.group(1))
    }

} else {
    log.error(&quot;Retry login also failed - both passwords incorrect&quot;)
}
</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PostProcessor>
