              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Handle Password Reset Response" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">// Check if password reset was successful or needs retry
def response = prev.getResponseDataAsString()

if (response.contains(&quot;successfully logged in&quot;) || response.contains(&quot;HREF.DUMMY.MENSYS.1&quot;)) {
    log.info(&quot;Password reset successful - extracting portal URL&quot;)

    // Extract PORTAL_URL
    def portalMatch = response =~ /name=&quot;HREF\.DUMMY\.MENSYS\.1&quot; value=&quot;([^&quot;]+)&quot;/
    if (portalMatch.find()) {
        vars.put(&quot;PORTAL_URL&quot;, portalMatch.group(1))
        log.info(&quot;Extracted PORTAL_URL: &quot; + portalMatch.group(1))
    }

    // Update PASSWORD variable for future use
    vars.put(&quot;PASSWORD&quot;, vars.get(&quot;NEW_PASSWORD&quot;))
    log.info(&quot;Password updated to NEW_PASSWORD for future logins&quot;)

} else if (response.contains(&quot;Password Error&quot;) || response.contains(&quot;Password Change&quot;)) {
    log.error(&quot;Password reset failed - check password requirements&quot;)
    log.error(&quot;Password must be 8+ chars with uppercase, lowercase, numbers, and special chars&quot;)
} else {
    log.warn(&quot;Unexpected password reset response&quot;)
}
</stringProp>
