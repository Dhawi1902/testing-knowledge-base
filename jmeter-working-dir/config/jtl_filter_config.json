{
  "filter": {
    "label_pattern": "^(?![A-Z]{2,4}\\d{4,7}$).*$",
    "exclude_embedded": true,
    "include_failed_only": false,
    "min_response_time_ms": null,
    "max_response_time_ms": null
  },
  "input": {
    "results_dir": "results",
    "jtl_pattern": "*.jtl",
    "use_latest": true
  },
  "output": {
    "filtered_suffix": "_filtered",
    "generate_html_report": true,
    "report_dir_suffix": "_report"
  },
  "jmeter": {
    "jmeter_home": null,
    "jmeter_cmd": "jmeter"
  }
}
